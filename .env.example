# Database Configuration
DATABASE_URL=postgresql://YOUR_LOCAL_USER:YOUR_LOCAL_PASSWORD@localhost:5432/finance_dashboard
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=finance_dashboard
DATABASE_USER=YOUR_LOCAL_USER
DATABASE_PASSWORD=YOUR_LOCAL_PASSWORD

# Google Sheets
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
GOOGLE_AUTH_METHOD=oauth
GOOGLE_OAUTH_CLIENT_SECRET_PATH=credentials/google_oauth_client_secret.json
GOOGLE_OAUTH_TOKEN_PATH=credentials/google_oauth_token.json

# Optional fallback if your Google Workspace permits service account keys
GOOGLE_SHEETS_JSON_KEY_PATH=credentials/google_sheets_credentials.json

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=True
API_RELOAD=True

# Sync Configuration
SYNC_INTERVAL_MINUTES=60
AUTO_SYNC_ON_STARTUP=False

# Logging
LOG_LEVEL=INFO
